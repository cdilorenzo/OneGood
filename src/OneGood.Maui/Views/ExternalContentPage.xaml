<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="OneGood.Maui.Views.ExternalContentPage"
             Title="{x:Static local:Resources.legal_external_title}">
    <ScrollView>
        <VerticalStackLayout Padding="20">
            <Label Text="{x:Static local:Resources.legal_external_disclaimer}" />
            <Label Text="{x:Static local:Resources.legal_external_no_donations}" Margin="0,10,0,0" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>