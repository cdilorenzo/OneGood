<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
        xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
        xmlns:views="clr-namespace:OneGood.Maui.Views"
        x:Class="OneGood.Maui.AppShell">
    <ShellContent Title="Causes" ContentTemplate="{DataTemplate views:CauseListPage}" />
    <ShellContent Route="imprint" Title="Imprint" ContentTemplate="{DataTemplate views:ImprintPage}" />
    <ShellContent Route="privacy" Title="Privacy" ContentTemplate="{DataTemplate views:PrivacyPage}" />
    <ShellContent Route="external" Title="External" ContentTemplate="{DataTemplate views:ExternalContentPage}" />
</Shell>
